# Kali Linux Connection Details
# Set KALI_HOST to the IP of your Kali VM (check with: ip addr show eth1)
KALI_HOST=192.168.1.206
KALI_PORT=22
# Use root for full tool access (nmap, sqlmap, etc. require root)
KALI_USERNAME=root

# Command execution timeout in milliseconds
# 900000000 = effectively unlimited (~250 hours) — safe for long nmap/sqlmap runs
# Set to 3600000 (1 hour) if you want a tighter cap
COMMAND_TIMEOUT=900000000

# SSH connection pool size — one persistent ControlMaster socket per slot.
# 5 is a good default; increase if you run many concurrent async jobs.
SSH_POOL_SIZE=5

# CLI bridge port (mcp-bridge container)
PORT=3001

# Desktop/GUI bridge port (desktop-bridge container)
DESKTOP_PORT=3002
