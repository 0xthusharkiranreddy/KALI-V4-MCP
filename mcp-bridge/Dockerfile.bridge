FROM node:20-alpine

RUN apk add --no-cache openssh-client bash wget

WORKDIR /app

# Install dependencies from lockfile (reproducible — exact versions pinned)
COPY package.json package-lock.json ./
RUN npm ci --production --no-audit --no-fund

COPY bridge-server.js .
COPY start-bridge.sh /start-bridge.sh
RUN chmod +x /start-bridge.sh

EXPOSE 3001

CMD ["/start-bridge.sh", "bridge-server.js"]
